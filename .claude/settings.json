        "hooks": [
          {
            "type": "command",
            "command": "bash /var/www/atendia/.claude/hooks/block-destructive-db.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
